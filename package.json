{
    "name": "archive-accelerator",
    "version": "0.1.0",
    "description": "Simplify and speed up working with past web page versions from archive.org",
    "main": "./out/main/index.js",
    "scripts": {
        "dev": "unset ELECTRON_RUN_AS_NODE && electron-vite dev",
        "build": "unset ELECTRON_RUN_AS_NODE && electron-vite build",
        "preview": "unset ELECTRON_RUN_AS_NODE && electron-vite preview",
        "postinstall": "electron-rebuild -f -w better-sqlite3",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "better-sqlite3": "^12.0.0",
        "diff": "^7.0.0",
        "dotenv": "^16.0.0",
        "echarts": "^5.6.0",
        "entities": "^8.0.0",
        "highlight.js": "^11.11.1",
        "lit": "^3.0.0",
        "parse5": "^8.0.0",
        "rapidhash-js": "^1.0.0"
    },
    "devDependencies": {
        "@electron/rebuild": "^3.0.0",
        "@tailwindcss/vite": "^4.0.0",
        "electron": "^39.0.0",
        "electron-vite": "^5.0.0",
        "tailwindcss": "^4.0.0",
        "vitest": "^4.1.2"
    }
}
