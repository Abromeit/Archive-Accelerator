{
    "name": "archive-accelerator",
    "version": "0.1.0",
    "description": "Simplify and speed up working with past web page versions from archive.org",
    "main": "./out/main/index.js",
    "productName": "Archive Accelerator",
    "scripts": {
        "dev": "unset ELECTRON_RUN_AS_NODE && electron-vite dev",
        "build": "unset ELECTRON_RUN_AS_NODE && electron-vite build",
        "preview": "unset ELECTRON_RUN_AS_NODE && electron-vite preview",
        "dist": "npm run build && electron-builder --mac",
        "postinstall": "electron-rebuild -f -w better-sqlite3",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "build": {
        "appId": "com.archive-accelerator.app",
        "productName": "Archive Accelerator",
        "mac": {
            "category": "public.app-category.productivity",
            "target": "dir"
        },
        "directories": {
            "output": "release"
        },
        "files": [
            "out/**/*",
            "node_modules/**/*"
        ],
        "extraMetadata": {
            "main": "./out/main/index.js"
        }
    },
    "dependencies": {
        "better-sqlite3": "^12.0.0",
        "diff": "^7.0.0",
        "dotenv": "^16.0.0",
        "echarts": "^5.6.0",
        "highlight.js": "^11.11.1",
        "lit": "^3.0.0",
        "parse5": "^8.0.0",
        "rapidhash-js": "^1.0.0"
    },
    "devDependencies": {
        "@electron/rebuild": "^3.0.0",
        "@tailwindcss/vite": "^4.0.0",
        "electron": "^39.0.0",
        "electron-builder": "^26.8.1",
        "electron-vite": "^5.0.0",
        "tailwindcss": "^4.0.0",
        "vitest": "^4.1.2"
    }
}
